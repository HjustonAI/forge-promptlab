{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Forge Heart Wiki — Claude Code settings. qmd MCP for retrieval. Hooks ship strict from day one (greenfield approach).",

  "mcpServers": {
    "qmd": {
      "command": "qmd",
      "args": ["mcp"],
      "env": {
        "QMD_EMBED_MODEL": "hf:Qwen/Qwen3-Embedding-0.6B-GGUF/Qwen3-Embedding-0.6B-Q8_0.gguf"
      }
    }
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/block-raw-edits.mjs" },
          { "type": "command", "command": "node .claude/hooks/validate-frontmatter.mjs" },
          { "type": "command", "command": "node .claude/hooks/check-dedupe-key.mjs" },
          { "type": "command", "command": "node .claude/hooks/enforce-tag-vocab.mjs" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/regenerate-index-json.mjs" }
        ]
      }
    ]
  },

  "permissions": {
    "allow": [
      "Bash(qmd status)",
      "Bash(qmd update)",
      "Bash(qmd embed)",
      "Bash(qmd embed -f)",
      "Bash(qmd cleanup)",
      "Bash(qmd search:*)",
      "Bash(qmd vsearch:*)",
      "Bash(qmd query:*)",
      "Bash(qmd get:*)",
      "Bash(qmd multi-get:*)",
      "Bash(qmd collection:*)",
      "Bash(qmd context:*)",
      "Bash(node .claude/skills/lint/build-index.mjs)",
      "Bash(node .claude/hooks/*.mjs)"
    ],
    "deny": []
  }
}
