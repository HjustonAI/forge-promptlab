# Forge Heart Wiki — qmd environment
# Copy to .qmd/env (gitignored) and source from your shell or setup.sh.

# Multilingual embedding model — covers PL + EN (operator has Polish sources).
# Default English-only model would mis-retrieve on Polish queries.
export QMD_EMBED_MODEL="hf:Qwen/Qwen3-Embedding-0.6B-GGUF/Qwen3-Embedding-0.6B-Q8_0.gguf"

# Optional: override the editor URI used by `qmd get` deep links.
# export QMD_EDITOR_URI="vscode://file/{path}:{line}"
